# TraderLens — env template
# Copy to .env and fill in real values. .env is gitignored.

# IBKR Flex Web Service credentials
# Apply at: https://www.interactivebrokers.com/sso/Authenticator → Reports → Flex Queries → Settings
IBKR_FLEX_TOKEN=your_flex_token_here
IBKR_FLEX_QUERY_ID=your_query_id_here

# Google Sheets (optional, can also use config/gsheet_key.json directly)
# GSHEET_SERVICE_ACCOUNT_KEY=./config/gsheet_key.json
# GSHEET_SPREADSHEET_ID=your_google_sheet_id_here
